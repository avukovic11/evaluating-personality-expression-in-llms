# Copy this file to `.env` (same directory) and fill in your key.
# `.env` is gitignored — do not commit it.
#
# Get the key from the OpenAI project that the team representative set up
# under the TakeLab organization.

OPENAI_API_KEY=opop

# Optional: pin a specific project ID if your key is multi-project.
# OPENAI_PROJECT=proj_...

# Optional: where to cache HuggingFace models (default is ~/.cache/huggingface).
# HF_HOME=
